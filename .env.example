# OpenAI Responses API. Never commit a real key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# Deterministic local/test adapter. Keep false for a live OpenAI run.
OPENAI_MOCK=false

# Development only: permit the controlled fixture on localhost/127.0.0.1.
ALLOW_LOCALHOST=false

# Production safety boundary. When true, only PUBLIC_APP_URL/demo/shop may run,
# rate limits become stricter, concurrent runs are blocked and GitHub writes fail.
SPECSENTRY_PUBLIC_DEMO=false

# Local SQLite database and screenshots are written below this directory.
SPECSENTRY_DATA_DIR=./data

# Server-only GitHub preview/export configuration. Export remains unavailable
# until every value is deliberately set, and is always blocked in public demo mode.
# Never prefix these with NEXT_PUBLIC_.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_REPOSITORY_ALLOWLIST=
PUBLIC_APP_URL=https://specsentry.example

# Deterministic local/Playwright adapter only. It is rejected in production.
GITHUB_MOCK=false
